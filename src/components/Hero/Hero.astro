---
import "./Hero.css";
---

<section class="px-[5%] py-16 md:py-24 lg:py-28">
  <div class="container">
    <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-2 md:gap-16">
      <div>
        <h1
          id="title"
          class="hero-title mb-5 text-6xl font-bold md:mb-6 md:text-9xl lg:text-10xl"
        >
          <span class="text-[#E63946]">Heads Up</span> Social
        </h1>
        <p id="subtitle" class="md:text-md pb-6">
          I got tired of missing platform updates. So I built a way to never
          miss one again.
        </p>

        <a
          href="https://gitlab.com/thefrontendmarketer/heads-up-social"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-md bg-[#E63946] px-4 py-2 font-sans text-white"
          >Build Your Own for <strong>FREE</strong></a
        >
      </div>
      <div class="relative flex w-full" data-hero-stack>
        <div class="absolute bottom-[10%] left-0 z-20 w-[35%]" data-hero-code>
          <img
            src="/images/code_400.webp"
            srcset="/images/code_400.webp 400w, /images/code_800.webp 800w"
            sizes="(max-width: 768px) 35vw, 22vw"
            width="400"
            height="394"
            alt="Code in code editor"
            loading="eager"
            decoding="async"
            class="aspect-square size-full object-cover rounded-lg"
          />
        </div>
        <div class="relative z-10 mx-[10%] w-full" data-hero-main>
          <img
            src="/images/site2_900.webp"
            srcset="/images/site2_900.webp 900w, /images/site2_1800.webp 1522w"
            sizes="(max-width: 768px) 80vw, 40vw"
            width="900"
            height="887"
            alt="Heads Up Social app"
            fetchpriority="high"
            decoding="async"
            class="rounded-lg h-auto w-full"
          />
        </div>
        <div class="absolute right-0 top-[10%] z-30 w-2/5" data-hero-repo>
          <img
            src="/images/gitlabrepo_450.webp"
            srcset="/images/gitlabrepo_450.webp 450w, /images/gitlabrepo_900.webp 900w"
            sizes="(max-width: 768px) 40vw, 25vw"
            width="450"
            height="411"
            alt="GitLab repo"
            loading="eager"
            decoding="async"
            class="aspect-3/2 size-full object-cover rounded-lg"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import "./Hero.js";
</script>
