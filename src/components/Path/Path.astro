---
import "./Path.css";
---

<section id="path" class="px-[5%] py-16 md:py-24 lg:py-28" data-path-section>
  <div class="mx-auto max-w-7xl">
    <div class="mb-4 md:mb-6">
      <div class="mx-auto w-full max-w-lg text-center">
        <h2 class="mb-5 text-5xl font-bold md:mb-6 md:text-7xl lg:text-8xl">
          Choose your path
        </h2>
        <p class="min-[959px]:hidden">Tap the path that feels right for you.</p>
        <p class="hidden min-[959px]:block">
          Move your heart along the path that feels right for you!
        </p>
      </div>
    </div>

    <!-- Desktop only: animated fork with draggable heart -->
    <div
      class="mb-10 hidden justify-center min-[959px]:mb-12 min-[959px]:flex"
      data-path-fork
    >
      <svg
        class="path-fork"
        data-path-svg
        viewBox="0 0 640 272"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path class="path-fork__line" data-path-stem d="M320 0 L320 88"></path>
        <path
          class="path-fork__line"
          data-path-left
          d="M320 88 C320 118, 282 134, 244 148 C206 162, 172 178, 158 196 C148 210, 146 228, 148 246"
        ></path>
        <path
          class="path-fork__line"
          data-path-right
          d="M320 88 C320 118, 358 134, 396 148 C434 162, 468 178, 482 196 C492 210, 494 228, 492 246"
        ></path>
        <circle class="path-fork__dot" data-path-dot cx="148" cy="246" r="3"
        ></circle>
        <circle class="path-fork__dot" data-path-dot cx="492" cy="246" r="3"
        ></circle>
        <g class="path-fork__handle" data-path-handle>
          <path
            d="M12 21 C12 21 3 13.8 3 8.4 C3 5.4 5.4 3 8.4 3 C10.3 3 11.5 4.2 12 5 C12.5 4.2 13.7 3 15.6 3 C18.6 3 21 5.4 21 8.4 C21 13.8 12 21 12 21 Z"
            transform="scale(1.35) translate(-12 -12)"></path>
        </g>
      </svg>
    </div>

    <div
      class="path-choices mx-auto grid max-w-5xl grid-cols-1 min-[959px]:grid-cols-2"
      data-path-choices
    >
      <div
        class="path-option"
        data-path-option
        data-path-choice="subscribe"
        role="button"
        tabindex="0"
      >
        <img
          src="/subscribe-icon.png"
          alt=""
          class="path-option__icon"
          aria-hidden="true"
        />
        <h3 class="path-option__title">Subscribe</h3>
      </div>

      <div
        class="path-option"
        data-path-option
        data-path-choice="build"
        role="button"
        tabindex="0"
      >
        <img
          src="/build-icon.png"
          alt=""
          class="path-option__icon"
          aria-hidden="true"
        />
        <h3 class="path-option__title">Build your own</h3>
      </div>
    </div>
  </div>
</section>

<script>
  import "./Path.js";
</script>
