---
const items = [
  {
    title:
      "Social media updates are scattered. \
Your attention shouldn't be.",
    body: "Platform updates are scattered across blogs, forums, podcasts, and other sources that most people don't have time to check every week.",
  },
  {
    title: "Heads Up!",
    body: "Heads Up Social is a fully customizable tool that helps you stay ahead of what's changing and how it affects your social media strategy.",
  },
];

type Platform = "YouTube" | "LinkedIn" | "Instagram";

interface Entry {
  platform: Platform;
  text: string;
}

const entries: Entry[] = [
  {
    platform: "YouTube",
    text: "Shorts shelf life cut from 14 days to 5 in the algorithm",
  },
  {
    platform: "LinkedIn",
    text: "Carousel posts now capped at 2x reach vs. native video",
  },
  {
    platform: "Instagram",
    text: "Reels now indexed by Google Search by default",
  },
];

const label = "changelog";
---

<section class="px-[5%] py-16 md:py-24 lg:py-28">
  <div class="mx-auto max-w-7xl">
    <div
      class="grid grid-cols-1 items-center gap-y-12 md:grid-cols-2 md:gap-x-12 lg:gap-x-20"
    >
      <div class="order-2 grid grid-cols-1 gap-y-10 md:order-2">
        {
          items.map((item) => (
            <div class="border-l-2 border-transparent pl-8">
              <h2 class="content-title mb-3 text-2xl font-bold md:mb-4 md:text-3xl md:leading-[1.3] lg:text-4xl">
                {item.title}
              </h2>
              <p>{item.body}</p>
            </div>
          ))
        }
      </div>

      <div
        class="order-1 w-full border border-zinc-800 bg-zinc-950 font-mono text-sm text-zinc-100 shadow-[8px_8px_0_0_var(--color-zinc-900)] md:order-1"
      >
        <div
          class="flex items-center justify-between border-b border-zinc-800 px-4 py-3"
        >
          <div class="flex items-center gap-2">
            <span class="size-2.5 rounded-full bg-[#FF605C]"></span>
            <span class="size-2.5 rounded-full bg-[#FFBD44]"></span>
            <span class="size-2.5 rounded-full bg-[#00CA4E]"></span>
          </div>
          <span class="text-xs text-zinc-400">{label}</span>
        </div>

        <ul class="divide-y divide-zinc-800/60">
          {
            entries.map((entry, i) => (
              <li class="flex items-start gap-3 px-4 py-3 leading-relaxed">
                <span class="mt-0.5 inline-flex size-4 shrink-0 items-center justify-center">
                  {entry.platform === "YouTube" && (
                    <img
                      src="/yt-icon.svg"
                      alt=""
                      class="size-4"
                      aria-hidden="true"
                    />
                  )}
                  {entry.platform === "LinkedIn" && (
                    <img
                      src="/li-icon.svg"
                      alt=""
                      class="size-4"
                      aria-hidden="true"
                    />
                  )}
                  {entry.platform === "Instagram" && (
                    <img
                      src="/ig-icon.svg"
                      alt=""
                      class="size-4"
                      aria-hidden="true"
                    />
                  )}
                </span>
                <span class="text-zinc-400">{entry.platform}</span>
                <span class="text-zinc-300" data-row={i}>
                  {entry.text}
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
