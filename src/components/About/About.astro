---
import "./About.css";

const features = [
  {
    title: "Here's the thing",
    body: "This isn't another social media news channel trying to cover everything for everyone. Heads Up Social exists to track the three platforms I actually use. Subscribe to get my version or build your own.",
    icon: "/time-icon.png",
  },
  {
    title: "Subscribe",
    body: "Don't want to build just yet? No worries! Subscribe to my version for YouTube, LinkedIn, and Instagram updates every Monday. No set up required.",
    icon: "/subscribe-icon.png",
  },
  {
    title: "Build your own",
    body: "This is why Heads Up Social exists! Grab the code, customize the platform list, run your own version. The whole point is so you can create your own that benefits your marketing strategy.",
    icon: "/build-icon.png",
  },
];
---

<section id="about" class="relative px-[5%] py-16 md:py-24 lg:py-28">
  <div class="relative z-10 mx-auto max-w-7xl">
    <div
      class="relative mx-auto mb-12 max-w-lg overflow-visible pt-8 text-center md:mb-18 lg:mb-20"
      data-about-heading
    >
      <div
        class="about-hearts-stage pointer-events-none absolute inset-x-0 bottom-0 h-28"
        data-about-hearts-stage
        aria-hidden="true"
      >
      </div>
      <h2 class="relative z-10 mb-5 text-white md:mb-6">
        Use mine or build your own
      </h2>
    </div>

    <div
      class="grid grid-cols-1 items-start gap-y-12 md:grid-cols-3 md:gap-x-8 lg:gap-x-12"
    >
      {
        features.map((feature) => (
          <div class="w-full text-center">
            <div class="mb-5 flex h-12 justify-center md:mb-6">
              <img src={feature.icon} class="size-12" alt="" />
            </div>
            <h3>{feature.title}</h3>
            <p class="text-zinc-200">{feature.body}</p>
          </div>
        ))
      }
    </div>
  </div>

  <div class="absolute inset-0 z-0">
    <img
      src="https://res.cloudinary.com/dhytwf10i/image/upload/f_auto,q_auto,w_1600/v1784067184/hearts_jgmory.png"
      class="absolute inset-0 size-full object-cover"
      alt="Social media hearts"
    />
    <div class="absolute inset-0 bg-black/50"></div>
  </div>
</section>

<script>
  import "./About.js";
</script>
