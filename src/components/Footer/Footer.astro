---
import "./Footer.css";
---

<section
  id="footer"
  class="px-[5%] pt-24 pb-12 md:pt-32 md:pb-18 lg:pt-40 lg:pb-20"
  data-footer
>
  <div class="mx-auto max-w-7xl">
    <div class="flex flex-col items-center pb-12 md:pb-18 lg:pb-20">
      <a
        href="/"
        class="mb-8 flex flex-col items-center justify-center gap-3 text-center"
        data-footer-brand
      >
        <img
          src="/nav-logo-200x200.png"
          alt="Heads Up Social logo"
          class="h-16 w-16 md:h-20 md:w-20"
          data-footer-logo
        />
        <span
          class="footer-title text-5xl font-bold md:text-6xl"
          style="font-family: 'Atomic Marker', ui-sans-serif, system-ui, sans-serif;"
          data-footer-title
        >
          <span class="footer-fill" data-footer-fill>
            <span class="footer-fill__base" data-footer-fill-base>Heads Up</span
            >
            <span
              class="footer-fill__red"
              aria-hidden="true"
              data-footer-fill-red>Heads Up</span
            >
          </span>
          {" "}Social
        </span>
      </a>
    </div>
    <div class="h-px w-full origin-left bg-zinc-800" data-footer-rule></div>
    <div
      class="flex flex-col-reverse items-center justify-between pb-4 pt-6 text-center text-sm md:flex-row md:pb-0 md:pt-8"
      data-footer-legal
    >
      <p class="mt-8 md:mt-0">© 2026 Heads Up Social. All rights reserved.</p>
      <ul
        class="grid grid-flow-row grid-cols-[max-content] justify-center gap-y-4 text-sm md:grid-flow-col md:gap-x-6 md:gap-y-0"
      >
        <li class="underline decoration-zinc-400 underline-offset-1">
          <a href="#">Privacy Policy</a>
        </li>
        <li class="underline decoration-zinc-400 underline-offset-1">
          <a href="#">Terms of Service</a>
        </li>
        <li class="underline decoration-zinc-400 underline-offset-1">
          <a href="#">Cookies Settings</a>
        </li>
      </ul>
    </div>
  </div>
</section>

<script>
  import "./Footer.js";
</script>
