---
const items = [
  {
    title:
      "Social media updates are scattered. \
Your attention shouldn't be.",
    body: "Platform updates are scattered across blogs, forums, podcasts, and other sources that most people don't have time to check every week.",
  },
  {
    title: "Heads Up!",
    body: "Heads Up Social is a fully customizable tool that helps you stay ahead of what's changing and how it affects your social media strategy.",
  },
];

type Platform = "youtube" | "linkedin" | "instagram";

interface Entry {
  platform: Platform;
  text: string;
}

const entries: Entry[] = [
  {
    platform: "youtube",
    text: "Shorts shelf life cut from 14 days to 5 in the algorithm",
  },
  {
    platform: "linkedin",
    text: "Carousel posts now capped at 2x reach vs. native video",
  },
  {
    platform: "instagram",
    text: "Reels now indexed by Google Search by default",
  },
];

const platformColor: Record<Platform, string> = {
  youtube: "text-[#FF0000]",
  linkedin: "text-[#0A66C2]",
  instagram: "text-[#c13584]",
};

const label = "platforms.changelog";
---

<section class="px-[5%] py-16 md:py-24 lg:py-28">
  <div class="mx-auto max-w-7xl">
    <div
      class="grid grid-cols-1 items-center gap-y-12 md:grid-cols-2 md:gap-x-12 lg:gap-x-20"
    >
      <div class="order-2 grid grid-cols-1 gap-y-10 md:order-1">
        {
          items.map((item) => (
            <div class="border-l-2 border-transparent pl-8">
              <h3 class="mb-3 text-2xl font-bold md:mb-4 md:text-3xl md:leading-[1.3] lg:text-4xl">
                {item.title}
              </h3>
              <p>{item.body}</p>
            </div>
          ))
        }
      </div>

      <div
        class="order-1 w-full border border-zinc-800 bg-zinc-950 font-mono text-sm text-zinc-100 shadow-[8px_8px_0_0_theme(colors.zinc.900)] md:order-2"
      >
        <div
          class="flex items-center justify-between border-b border-zinc-800 px-4 py-3"
        >
          <div class="flex items-center gap-2">
            <span class="size-2.5 rounded-full bg-red-900/40"></span>
            <span class="size-2.5 rounded-full bg-amber-900/40"></span>
            <span class="size-2.5 rounded-full bg-emerald-900/40"></span>
          </div>
          <span class="text-xs text-zinc-500">{label}</span>
        </div>

        <ul class="divide-y divide-zinc-800/60">
          {
            entries.map((entry, i) => (
              <li class="flex items-start gap-3 px-4 py-3 leading-relaxed">
                <span
                  class:list={[
                    "mt-0.5 inline-flex shrink-0",
                    platformColor[entry.platform],
                  ]}
                >
                  {entry.platform === "youtube" && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="size-4"
                      aria-hidden="true"
                    >
                      <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.5 31.5 0 0 0 0 12a31.5 31.5 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.5 31.5 0 0 0 24 12a31.5 31.5 0 0 0-.5-5.8zM9.75 15.5v-7l6.5 3.5-6.5 3.5z" />
                    </svg>
                  )}
                  {entry.platform === "linkedin" && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="size-4"
                      aria-hidden="true"
                    >
                      <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.23 0H1.77A1.75 1.75 0 0 0 0 1.73v20.54C0 23.2.78 24 1.77 24h20.46c.98 0 1.77-.8 1.77-1.73V1.73C24 .8 23.2 0 22.23 0z" />
                    </svg>
                  )}
                  {entry.platform === "instagram" && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="size-4"
                      aria-hidden="true"
                    >
                      <path d="M12 2.16c3.2 0 3.58.01 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.64.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92-.06-1.27-.07-1.64-.07-4.85s.01-3.58.07-4.85C2.38 3.92 3.9 2.38 7.15 2.23 8.42 2.17 8.8 2.16 12 2.16zm0-2.16C8.74 0 8.33.01 7.05.07 2.7.27.27 2.69.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.2 4.36 2.62 6.78 6.98 6.98C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c4.35-.2 6.78-2.62 6.98-6.98.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95C23.73 2.7 21.31.27 16.95.07 15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.41-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z" />
                    </svg>
                  )}
                </span>
                <span class="text-zinc-500">{entry.platform}</span>
                <span class="text-zinc-300" data-row={i}>
                  {entry.text}
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
