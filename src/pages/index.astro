---
import "../styles/global.css";
import Navbar from "../components/Navbar/Navbar.astro";
import Hero from "../components/Hero/Hero.astro";
import Issue from "../components/Issue/Issue.astro";
import About from "../components/About/About.astro";
import Path from "../components/Path/Path.astro";
import Footer from "../components/Footer/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <!--
      OS/browser scheme only. No media-less fallback — Chrome often picks
      the last matching rel=icon, and an unscoped link always matches.
    -->
    <link
      rel="icon"
      href="/white-icon.png?v=2"
      type="image/png"
      media="(prefers-color-scheme: dark)"
    />
    <link
      rel="icon"
      href="/favicon.ico?v=2"
      type="image/x-icon"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="icon"
      href="/favicon.ico?v=2"
      type="image/x-icon"
      media="(prefers-color-scheme: no-preference)"
    />
    <link
      rel="preload"
      href="/atomic-marker.woff"
      as="font"
      type="font/woff"
      crossorigin
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Heads Up Social is a tool to help you stay informed about social media updates, news, and how it impacts your marketing strategy."
    />
    <title>Heads Up Social</title>
  </head>
  <body>
    <header>
      <Navbar />
    </header>
    <main>
      <Hero />
      <Issue />
      <About />
      <Path />
    </main>
    <footer>
      <Footer />
    </footer>
  </body>
</html>
